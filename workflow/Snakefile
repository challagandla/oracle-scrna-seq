rule all:
    input:
        RAW_FASTQ_QC_TARGETS,
        # Per-sample QC + doublet removal
        expand(result_path("{sample}/01_doublets/no_doublets.h5ad"), sample=SAMPLES),
        # Merged & normalized
        result_path("merged/02_normalize/normalized.h5ad"),
        # HVG + PCA
        result_path("merged/03_hvg_pca/hvg_pca.h5ad"),
        # Batch-corrected (or copy if no batch)
        result_path("merged/04_batch/batch_corrected.h5ad"),
        # Embedding
        result_path("merged/05_embedding/embedded.h5ad"),
        # Clustering
        result_path("merged/06_cluster/clustered.h5ad"),
        # Marker genes
        result_path("merged/07_markers/with_markers.h5ad"),
        result_path("merged/07_markers/pseudobulk_status.csv"),
        result_path("merged/07_markers/DE"),
        # Cell type annotation
        result_path("merged/08_annotate/annotated.h5ad"),
        result_path("merged/08_annotate/annotation_summary.csv"),
        result_path("merged/08_annotate/marker_coverage.csv"),
        result_path("merged/08_annotate/composition_by_sample.csv"),
        TRAJECTORY_TARGETS,
        # HTML reports
        result_path("report.html"),
        result_path("run_manifest.json"),
        MULTIQC_REPORT,
